---
import RequestAQuoteButton from "./RequestAQuoteButton.astro";

interface Props {
    displayRequestAQuoteButton : boolean;
    title: string;
    subtext: string;
}

const {displayRequestAQuoteButton, title, subtext} = Astro.props;
---
<div class="bg-white p-6 rounded-2xl border border-gray-100 shadow-sm">

    <div class="w-12 h-12 rounded-lg flex items-center justify-center mb-4">
        <slot name="icon" />
    </div>

    <h3 class="text-xl font-bold text-[--color-brand-blue] mb-2">{title}</h3>
    <p class="text-[--color-text-main] opacity-70 mb-4">{subtext}</p>

    <!-- Lista de Checkmarks
