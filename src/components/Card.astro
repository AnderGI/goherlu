        <li class="flex items-center gap-2">✅ Materiales de primera calidad</li>
        <li class="flex items-center gap-2">✅ Garantía de 2 años</li>
    </ul>
    <RequestAQuoteButton displayLogo={false} isVisible={displayRequestAQuoteButton}/>
-->
