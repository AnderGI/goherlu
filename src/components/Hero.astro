---
import infoSquare from "../assets/infoSquare.svg"
import whatsapp from "../assets/whatsapp.svg"
import RequestAQuoteButton from "./RequestAQuoteButton.astro";
import WhatsappContactButton from "./WhatsappContactButton.astro";
import OurServices from "./OurServices.astro";
import Spacer from "./Spacer.astro";
import ReasonsToChooseUs from "./ReasonsToChooseUs.astro";
import FinalCallToAction from "./FinalCallToAction.astro";
import Benefits from "./Benefits.astro";
import CallNowButton from "./CallNowButton.astro";
import Testimonial from "./Testimonial.astro";
---

<main class="py-16 px-4">
    <div class="flex flex-col w-full">

            <h1 class="text-4xl font-bold mb-6 flex flex-col justify-center content-center">
                <span>Tu instalación,</span>
                <span>sin preocupaciones.</span>
            </h1>
            <p class="text-lg md:text-xl text-[--color-text-main] opacity-80 mb-10 leading-relaxed">
                17 años de experiencia en el País Vasco.
            </p>
            <CallNowButton />

        <section class="py-16 flex flex-col gap-3">
            <Testimonial
                    name="Iker Etxebarria"
                    role="Construcciones Arana"
                    quote="Excelente servicio. Vinieron rápido, diagnosticaron el problema y lo solucionaron en el mismo día. Muy profesionales y atentos."
            />

            <Testimonial
                    name="Jon Garitano"
                    role="Talleres Mendizabal"
                    quote="Llevamos años trabajando con ellos para el mantenimiento de nuestras instalaciones. Siempre disponibles y resolutivos."
            />
            <Testimonial
                    name="Amaia Zubieta"
                    role="Hostal Txoko"
                    quote="Hicieron toda la instalación eléctrica de nuestro nuevo local. Trabajo impecable, cumplieron los plazos y el precio fue muy ajustado."
            />
            <Testimonial
                    name="Leire Aranburu"
                    role="Particular"
                    quote="Reformaron toda la instalación eléctrica de mi casa. Muy contentos con el resultado, ahora todo funciona perfectamente."
            />
        </section>

    </div>
</main>

<style>

    main > div {
        padding-top: 5rem;
    }
    h1 {
        color: var(--color-brand-blue);
        text-align: left;
    }
    h1 span:last-child {
        color: var(--color-urgency-red);
    }
</style>