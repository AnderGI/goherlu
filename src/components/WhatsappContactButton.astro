---
import whatsapp from "../assets/whatsapp.svg"
---
<a id="whatsappbtn" href="https://wa.me/688635518" class="flex items-center justify-center gap-2 font-extrabold py-4 px-8 rounded-xl text-center shadow-lg active:scale-[0.98] transition-all text-lg">
    <span>Contactar por WhatsApp</span>
    <img src={whatsapp.src} alt="WhatsApp" class="w-6 h-6" />
</a>


<style>
    a#whatsappbtn {
        background: var(--color-action-whatsapp);
        color: var(--color-bg-white);
    }
</style>