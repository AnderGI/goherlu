---
import doubleCheck from "../assets/doubleCheck.svg"
// Benefits.astro
const benefits = [
    { title: "Rapidez", desc: "Respuesta en menos de 24 horas para urgencias" },
    { title: "Experiencia", desc: "Más de 17 años en el sector eléctrico" },
    { title: "Profesionalidad", desc: "Técnicos certificados y cualificados" },
    { title: "Atención personalizada", desc: "Soluciones adaptadas a cada cliente" }
];
---

<section class="py-12 px-6">
    <h2 class="text-2xl font-extrabold text-[--color-brand-blue] text-center mb-8">¿Por qué elegirnos?</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {benefits.map(item => (
                <div class="flex items-center gap-4 p-4">
                    <div class="text-[--color-brand-blue]">
                        <img src={doubleCheck.src} class="w-10 h-10" alt="Icono" />
                    </div>
                    <div>
                        <h3 class="font-bold text-[--color-brand-blue]">{item.title}</h3>
                        <p class="text-sm text-[--color-text-main] opacity-70">{item.desc}</p>
                    </div>
                </div>
        ))}
    </div>
</section>

<style>
    h2, h3 {
        color: var(--color-brand-blue);
    }
</style>