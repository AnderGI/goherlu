---
import doubleCheck from "../assets/doubleCheck.svg"
// Benefits.astro
const benefits = [
    {
        emoji: "⚡",
        title: "Respuesta en <24h",
        desc: "Solucionamos tu urgencia hoy mismo."
    },
    {
        emoji: "🛠️",
        title: "+17 años de oficio",
        desc: "Cero experimentos con tus cables."
    },
    {
        emoji: "📜",
        title: "Técnicos homologados",
        desc: "Seguridad y garantía oficial."
    },
    {
        emoji: "💰",
        title: "Presupuesto cerrado",
        desc: "Sin sorpresas ni letra pequeña."
    }
];
---

<section class="py-12 px-6">
    <h2 class="text-2xl font-extrabold text-[--color-brand-blue] text-center mb-8">¿Por qué elegirnos?</h2>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {benefits.map(item => (
                <div class="flex items-center gap-4 p-4">
                    <div>
                        <h3 class="font-bold text-[--color-brand-blue]">{item.emoji} {item.title}</h3>
                        <p class="text-sm text-[--color-text-main] opacity-70">{item.desc}</p>
                    </div>
                </div>
        ))}
    </div>
</section>

<style>
    h2, h3 {
        color: var(--color-brand-blue);
    }
</style>